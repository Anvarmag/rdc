# ==========================================================================
# РДЦ - Радиологический дата-центр
# .gitignore - Файлы и папки, исключаемые из Git
# ==========================================================================

# ==================== OS Generated Files ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==================== Python ====================
__pycache__/
*.pyc

# ==================== IDE / Editor ====================
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.settings/
.classpath
*.iml

# ==================== Node.js ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ==================== Build Output ====================
dist/
build/
out/
.cache/
.parcel-cache/
.next/
.nuxt/

# ==================== Environment ====================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ==================== Logs ====================
logs/
*.log
npm-debug.log*

# ==================== Testing ====================
coverage/
.nyc_output/
test-results/

# ==================== Temp Files ====================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# ==================== Documentation Build ====================
docs/_build/

# ==================== Deployment ====================
.vercel
.netlify

# ==================== Project Specific ====================
# Local configuration files
config.local.js
secrets.json

# Uploaded files (if any local uploads)
uploads/
user-content/

# Backup files
*.sql.bak
